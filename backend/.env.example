# Redis explicitly needs rediss:// for Upstash
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@champion-marlin-68259.upstash.io:6379/0

# MongoDB correctly needs mongodb+srv with retryWrites
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@ac-h4j3isr.v2w74su.mongodb.net/YOUR_DB?retryWrites=true&w=majority

# Other secrets
JWT_SECRET_KEY=super-secret-key
JWT_ACCESS_TOKEN_EXPIRES=1800

# Mail credentials — use a Gmail App Password, NOT your real Google password
# To create one: Google Account → Security → 2-Step Verification → App Passwords → create for "Mail"
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# Frontend URL — used in password reset email links
# Set this to your Vercel app URL in production (e.g. https://checkmyurl.vercel.app)
FRONTEND_URL=http://localhost:5173
