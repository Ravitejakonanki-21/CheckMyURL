# Redis explicitly needs rediss:// for Upstash
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@champion-marlin-68259.upstash.io:6379/0

# MongoDB correctly needs mongodb+srv with retryWrites
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@ac-h4j3isr.v2w74su.mongodb.net/YOUR_DB?retryWrites=true&w=majority

# Other secrets
JWT_SECRET_KEY=super-secret-key
JWT_ACCESS_TOKEN_EXPIRES=1800

# Mail credentials
