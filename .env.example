JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRES=1800

MONGO_URI=mongodb://mongo:27017/url_checker
MONGO_DB_NAME=url_checker
MONGO_MAX_POOL_SIZE=100
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# For rediss:// (TLS): CERT_REQUIRED or CERT_NONE (Upstash often needs CERT_NONE)
REDIS_SSL_CERT_REQS=CERT_REQUIRED

# For MongoDB Atlas TLS handshake: set true if cert verification fails
MONGO_TLS_ALLOW_INVALID_CERTIFICATES=false
CELERY_PREFETCH_MULTIPLIER=4
CELERY_TASK_TIME_LIMIT=120
CELERY_TASK_SOFT_TIME_LIMIT=90

# SMTP credentials for password-reset emails
MAIL_USERNAME=your-smtp-user
MAIL_PASSWORD=your-smtp-password

# URL of the frontend (used in password-reset email links)
FRONTEND_URL=http://localhost:3000
